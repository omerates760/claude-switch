#!/usr/bin/env bash
# claude-switch — switch between Claude profiles (Code + Desktop together).
#
# Usage:
#   claude-switch                    list profiles, mark active
#   claude-switch <profile>          switch to <profile>
#   claude-switch init <profile>     move existing Claude state into a new profile (run once)
#   claude-switch add <profile>      create empty profile (login required after switch)
#   claude-switch remove <profile>   delete profile (data + keychain backups)
#   claude-switch current            print active profile
#
# Layout per profile:
#   ~/.claude-profiles/<profile>/code/         ← symlinked to ~/.claude
#   ~/.claude-profiles/<profile>/desktop/      ← symlinked to ~/Library/Application Support/Claude
#   ~/.claude-profiles/<profile>/claude.json   ← symlinked to ~/.claude.json (Code identity cache)
#   Keychain backups: "Claude Code-credentials-profile-<name>",
#                     "Claude Safe Storage-profile-<name>"

set -euo pipefail

PROFILES_DIR="$HOME/.claude-profiles"
ACTIVE_FILE="$PROFILES_DIR/.active"

CODE_LINK="$HOME/.claude"
DESKTOP_LINK="$HOME/Library/Application Support/Claude"
JSON_LINK="$HOME/.claude.json"

KC_CODE_LIVE="Claude Code-credentials"
KC_CODE_BACKUP_PREFIX="Claude Code-credentials-profile-"
KC_DESKTOP_LIVE="Claude Safe Storage"
KC_DESKTOP_BACKUP_PREFIX="Claude Safe Storage-profile-"

c_red()    { printf '\033[31m%s\033[0m\n' "$*"; }
c_green()  { printf '\033[32m%s\033[0m\n' "$*"; }
c_yellow() { printf '\033[33m%s\033[0m\n' "$*"; }
c_bold()   { printf '\033[1m%s\033[0m\n' "$*"; }

die() { c_red "Error: $*" >&2; exit 1; }

require_macos() {
    [[ "$(uname -s)" == "Darwin" ]] || die "claude-switch requires macOS."
}

check_desktop_running() {
    if pgrep -x "Claude" >/dev/null 2>&1; then
        die "Claude Desktop is running. Quit it (Cmd+Q) before switching."
    fi
}

profile_dir()         { echo "$PROFILES_DIR/$1"; }
profile_code_dir()    { echo "$PROFILES_DIR/$1/code"; }
profile_desktop_dir() { echo "$PROFILES_DIR/$1/desktop"; }
profile_json_file()   { echo "$PROFILES_DIR/$1/claude.json"; }

current_profile() {
    [[ -f "$ACTIVE_FILE" ]] && cat "$ACTIVE_FILE" || echo ""
}

set_active() { echo "$1" > "$ACTIVE_FILE"; }

# ---- Keychain helpers (generic) ----
#
# Claude Code/Desktop store credentials with a service-specific account
# (e.g. acct=<username>) and look the entry up by (svce, acct). We must
# preserve the original acct when shuttling between live and backup, or
# the host app can't find its credential and prompts to log in again.

kc_account_of() {
    # Print the acct attribute of the first matching entry, or empty.
    security find-generic-password -s "$1" 2>/dev/null \
        | awk -F'"' '/"acct"<blob>=/ { print $4; exit }'
}

kc_delete_all() {
    # `security delete-generic-password -s` removes one entry per call;
    # loop so duplicates can't survive a restore.
    while security delete-generic-password -s "$1" >/dev/null 2>&1; do :; done
}

kc_backup() {
    local live_service="$1" backup_service="$2" cred acct
    cred=$(security find-generic-password -s "$live_service" -w 2>/dev/null) || return 0
    acct=$(kc_account_of "$live_service")
    kc_delete_all "$backup_service"
    security add-generic-password -s "$backup_service" -a "$acct" -w "$cred"
}

kc_restore() {
    local live_service="$1" backup_service="$2" cred acct
    if cred=$(security find-generic-password -s "$backup_service" -w 2>/dev/null); then
        acct=$(kc_account_of "$backup_service")
        kc_delete_all "$live_service"
        security add-generic-password -s "$live_service" -a "$acct" -w "$cred"
        return 0
    fi
    kc_delete_all "$live_service"
    return 1
}

backup_kc_for() {
    local profile="$1"
    kc_backup "$KC_CODE_LIVE"    "${KC_CODE_BACKUP_PREFIX}${profile}"
    kc_backup "$KC_DESKTOP_LIVE" "${KC_DESKTOP_BACKUP_PREFIX}${profile}"
}

restore_kc_for() {
    local profile="$1" code_ok=0 desktop_ok=0
    kc_restore "$KC_CODE_LIVE"    "${KC_CODE_BACKUP_PREFIX}${profile}"    && code_ok=1 || true
    kc_restore "$KC_DESKTOP_LIVE" "${KC_DESKTOP_BACKUP_PREFIX}${profile}" && desktop_ok=1 || true
    echo "$code_ok $desktop_ok"
}

# ---- Symlink swap ----

swap_link() {
    local link="$1" target="$2"
    if [[ -L "$link" ]]; then
        rm "$link"
    elif [[ -e "$link" ]]; then
        die "$link is a real path, not a symlink. Run: claude-switch init <name> first."
    fi
    ln -s "$target" "$link"
}

# ---- Commands ----

list_profiles() {
    [[ -d "$PROFILES_DIR" ]] || { echo "(no profiles)"; return; }
    local current any=0
    current=$(current_profile)
    for d in "$PROFILES_DIR"/*/; do
        [[ -d "$d" ]] || continue
        any=1
        local name; name=$(basename "$d")
        if [[ "$name" == "$current" ]]; then
            c_green "* $name (active)"
        else
            echo "  $name"
        fi
    done
    [[ $any -eq 1 ]] || echo "(none — run: claude-switch init <name>)"
}

cmd_init() {
    local profile="${1:-}"
    [[ -n "$profile" ]] || die "Usage: claude-switch init <profile>"
    check_desktop_running

    local pdir code_target desktop_target json_target
    pdir=$(profile_dir "$profile")
    code_target=$(profile_code_dir "$profile")
    desktop_target=$(profile_desktop_dir "$profile")
    json_target=$(profile_json_file "$profile")
    [[ ! -e "$pdir" ]] || die "Profile '$profile' already exists"

    [[ ! -L "$CODE_LINK" ]]    || die "$CODE_LINK is already a symlink. init was already run."
    [[ ! -L "$DESKTOP_LINK" ]] || die "$DESKTOP_LINK is already a symlink. init was already run."
    [[ ! -L "$JSON_LINK" ]]    || die "$JSON_LINK is already a symlink. init was already run."

    mkdir -p "$pdir"
    chmod 700 "$PROFILES_DIR" "$pdir"

    if [[ -d "$CODE_LINK" ]]; then
        c_yellow "Moving $CODE_LINK → $code_target"
        mv "$CODE_LINK" "$code_target"
    else
        c_yellow "$CODE_LINK not found — creating empty"
        mkdir -p "$code_target"
    fi
    ln -s "$code_target" "$CODE_LINK"

    if [[ -d "$DESKTOP_LINK" ]]; then
        c_yellow "Moving $DESKTOP_LINK → $desktop_target"
        mv "$DESKTOP_LINK" "$desktop_target"
    else
        c_yellow "$DESKTOP_LINK not found — creating empty (Desktop will populate on launch)"
        mkdir -p "$desktop_target"
    fi
    ln -s "$desktop_target" "$DESKTOP_LINK"

    if [[ -f "$JSON_LINK" ]]; then
        c_yellow "Moving $JSON_LINK → $json_target"
        mv "$JSON_LINK" "$json_target"
    else
        c_yellow "$JSON_LINK not found — Code will create on first login"
    fi
    ln -s "$json_target" "$JSON_LINK"

    backup_kc_for "$profile"
    set_active "$profile"
    c_green "Initialized '$profile' as active profile."
    echo "Next: claude-switch add <other> ; claude-switch <other> ; log in to Code + Desktop."
}

cmd_add() {
    local profile="${1:-}"
    [[ -n "$profile" ]] || die "Usage: claude-switch add <profile>"
    local pdir; pdir=$(profile_dir "$profile")
    [[ ! -e "$pdir" ]] || die "Profile '$profile' already exists"
    mkdir -p "$(profile_code_dir "$profile")" "$(profile_desktop_dir "$profile")"
    chmod 700 "$pdir"
    c_green "Created empty profile '$profile'. Switch to it, then log in to Code + Desktop."
}

cmd_remove() {
    local profile="${1:-}"
    [[ -n "$profile" ]] || die "Usage: claude-switch remove <profile>"
    local pdir; pdir=$(profile_dir "$profile")
    [[ -d "$pdir" ]] || die "Profile '$profile' not found"
    [[ "$(current_profile)" != "$profile" ]] || die "Cannot remove active profile. Switch away first."
    c_yellow "About to permanently delete: $pdir"
    read -rp "Type the profile name '$profile' to confirm: " confirm
    [[ "$confirm" == "$profile" ]] || die "Cancelled."
    rm -rf "$pdir"
    security delete-generic-password -s "${KC_CODE_BACKUP_PREFIX}${profile}"    >/dev/null 2>&1 || true
    security delete-generic-password -s "${KC_DESKTOP_BACKUP_PREFIX}${profile}" >/dev/null 2>&1 || true
    c_green "Removed '$profile'"
}

cmd_switch() {
    local target_profile="$1"
    local pdir; pdir=$(profile_dir "$target_profile")
    [[ -d "$pdir" ]] || die "Profile '$target_profile' not found. Run: claude-switch list"

    check_desktop_running

    local current; current=$(current_profile)
    if [[ "$current" == "$target_profile" ]]; then
        c_green "Already on '$target_profile'."
        return 0
    fi

    [[ -n "$current" ]] && backup_kc_for "$current"

    # One-time migration: pre-fix versions did not manage ~/.claude.json, so it
    # may exist as a real file. Move it into the departing profile to preserve
    # that account's cached identity (email/org) before repointing the symlink.
    if [[ -e "$JSON_LINK" && ! -L "$JSON_LINK" ]]; then
        if [[ -n "$current" ]]; then
            c_yellow "Migrating $JSON_LINK → $(profile_json_file "$current") (one-time)"
            mv "$JSON_LINK" "$(profile_json_file "$current")"
        else
            die "$JSON_LINK is a real file but no active profile is set. Run: claude-switch init <name>."
        fi
    fi

    swap_link "$CODE_LINK"    "$(profile_code_dir    "$target_profile")"
    swap_link "$DESKTOP_LINK" "$(profile_desktop_dir "$target_profile")"
    swap_link "$JSON_LINK"    "$(profile_json_file   "$target_profile")"

    local res; res=$(restore_kc_for "$target_profile")
    local code_ok desktop_ok
    code_ok=${res% *}; desktop_ok=${res#* }

    set_active "$target_profile"

    c_green "Switched to '$target_profile'."
    [[ "$code_ok" -eq 1 ]]    || c_yellow "  Code: no saved credential — run 'claude' to log in."
    [[ "$desktop_ok" -eq 1 ]] || c_yellow "  Desktop: no saved credential — open Claude.app to log in."
}

main() {
    require_macos
    local cmd="${1:-}"
    case "$cmd" in
        ""|list|ls)
            c_bold "Current: $(current_profile || echo "(none)")"
            echo
            c_bold "Profiles:"
            list_profiles
            ;;
        current)   current_profile ;;
        init)      cmd_init   "${2:-}" ;;
        add)       cmd_add    "${2:-}" ;;
        remove|rm) cmd_remove "${2:-}" ;;
        -h|--help|help)
            sed -n '2,18p' "$0"
            ;;
        *) cmd_switch "$cmd" ;;
    esac
}

main "$@"
